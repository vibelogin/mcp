{
  "compilerOptions": {
    "target": "es2022",
    "module": "es2022",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowJs": false,
    "types": ["node"],
    "lib": ["es2022"],
    "isolatedModules": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["src/__tests__/**"]
}
